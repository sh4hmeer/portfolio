---
// Big "PROJECTS" title screen that announces the work (clarissemichard.com style),
// leading into the pinned, receding clinic project below.
---
<section id="projects" class="projects-intro panel">
  <div class="pi-grid">
    <span class="pi-side l">some<br />selected</span>
    <h2 class="pi-title">PROJECTS</h2>
    <span class="pi-side r">live<br />in&nbsp;page</span>
  </div>
  <p class="pi-sub">Customer work, personal projects, some research and a playground.</p>
  <p class="pi-hint" aria-hidden="true">scroll to walk through them ↓</p>
</section>

<style>
  .projects-intro {
    min-height: 100vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 80px var(--pad);
  }
  .pi-grid {
    display: flex; align-items: center; justify-content: center; gap: 22px;
    width: 100%;
  }
  .pi-side {
    font-family: var(--mono); font-size: clamp(11px, 1.1vw, 13px);
    letter-spacing: .14em; text-transform: uppercase; color: var(--ink-faint);
    line-height: 1.4; white-space: nowrap; flex: none;
  }
  .pi-side.l { text-align: right; }
  .pi-side.r { text-align: left; }
  .pi-title {
    font-family: var(--display); font-weight: 800;
    font-size: clamp(64px, 17vw, 240px); line-height: .86;
    letter-spacing: -.045em; margin: 0; color: var(--ink);
  }
  .pi-sub {
    font-family: var(--mono); font-size: clamp(12.5px, 1.5vw, 16px);
    letter-spacing: .04em; text-transform: uppercase; color: var(--ink-dim);
    margin: 26px 0 0; max-width: 40ch;
  }
  .pi-hint {
    font-family: var(--mono); font-size: 12px; color: var(--ink-faint);
    margin: 54px 0 0; animation: bob 2.2s ease-in-out infinite;
  }
  @media (max-width: 700px) {
    .pi-grid { flex-direction: column; gap: 12px; }
    .pi-side { white-space: normal; }
    .pi-side br { display: none; }
  }
</style>
