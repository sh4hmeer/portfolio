---
// EMR Race — Manual Entry vs. Automated Watcher.
// Ported faithfully from the design handoff (design_handoff_emr_race): markup is
// the authored template verbatim; the Component logic is reproduced with the
// `setInterval` tweens converted to requestAnimationFrame (same durations/easing)
// and the standalone's window.scroll calls neutralised (it lives in the page now).
// Values/fields are the real Topcon Omnia TRK-3 -> OSCAR set.
---
<div class="bench-scene" data-bench-scene>
<div class="emr-root" style="background:#0e1116; font-family:'IBM Plex Sans',system-ui,sans-serif; color:#e7ecf3; padding:30px 30px 40px; box-sizing:border-box;">

  <div style="display:flex; align-items:flex-end; justify-content:space-between; gap:20px; max-width:1160px; margin:0 auto 20px;">
    <div>
      <div style="font:600 19px/1.2 'IBM Plex Sans'; letter-spacing:-.01em;">Manual Entry vs. Automated Watcher</div>
      <div style="font:400 12.5px/1.4 'IBM Plex Sans'; color:#8a93a0; margin-top:5px;">One biometer printout &middot; eight EMR fields buried in the noise &middot; two ways to move them.</div>
    </div>
    <div style="display:flex; gap:10px;">
      <button data-start style="background:#F76B54; color:#fff; border:none; padding:10px 18px; border-radius:7px; font:600 13px 'IBM Plex Sans'; cursor:pointer; box-shadow:0 1px 2px rgba(0,0,0,.08);">Start race</button>
      <button data-reset style="background:#0c0f14; border:1px solid #2a313d; color:#c8d0db; padding:10px 16px; border-radius:7px; font:600 13px 'IBM Plex Sans'; cursor:pointer;">Reset</button>
    </div>
  </div>

  <div class="emr-inner" style="max-width:1160px; margin:0 auto; position:relative; display:flex; flex-direction:column; gap:16px;">

    <!-- ================= MANUAL LANE ================= -->
    <div data-lanecard data-lane="manual" style="position:relative; background:#161b22; border:1px solid #272e39; border-radius:10px; padding:15px 18px 18px; box-shadow:0 1px 0 rgba(0,0,0,.02);">
      <div style="display:flex; align-items:center; gap:13px; margin-bottom:14px;">
        <span style="display:inline-flex; align-items:center; gap:7px; font:600 12px 'IBM Plex Sans'; color:#fff; background:#6B7B92; padding:5px 11px; border-radius:6px;">
          <span style="width:7px; height:7px; border-radius:50%; background:#d7dde6; opacity:.85;"></span>Manual Entry
        </span>
        <span style="font:400 11.5px 'IBM Plex Sans'; color:#7e8a9a;">Staffer reads the paper printout</span>
        <div style="margin-left:auto; display:flex; align-items:stretch;">
          <div style="display:flex; flex-direction:column; gap:3px; padding:0 16px; text-align:right;">
            <span style="font:500 9px 'IBM Plex Sans'; letter-spacing:.13em; text-transform:uppercase; color:#6f7a8a;">Time</span>
            <span data-clock data-lane="manual" style="font:500 17px/1 'IBM Plex Mono'; color:#dbe2ea;">00:00.00</span>
          </div>
          <div style="width:1px; background:#2a313d;"></div>
          <div style="display:flex; flex-direction:column; gap:3px; padding:0 16px; text-align:right;">
            <span style="font:500 9px 'IBM Plex Sans'; letter-spacing:.13em; text-transform:uppercase; color:#6f7a8a;">Keystrokes</span>
            <span data-actions data-lane="manual" style="font:500 17px/1 'IBM Plex Mono'; color:#dbe2ea;">0</span>
          </div>
          <div style="width:1px; background:#2a313d;"></div>
          <div style="display:flex; flex-direction:column; gap:3px; padding:0 0 0 16px; text-align:right;">
            <span style="font:500 9px 'IBM Plex Sans'; letter-spacing:.13em; text-transform:uppercase; color:#6f7a8a;">Errors</span>
            <span data-errors data-lane="manual" style="font:500 17px/1 'IBM Plex Mono'; color:#dbe2ea;">0</span>
          </div>
        </div>
      </div>

      <div data-body data-lane="manual" style="position:relative; display:flex; align-items:center; min-height:336px;">
        <div data-machine data-lane="manual" style="width:118px; flex:none; margin-right:18px; align-self:flex-start; padding-top:6px; display:flex; flex-direction:column; align-items:center; gap:5px;">
          <svg width="104" height="118" viewBox="0 0 108 122">
            <rect x="10" y="6" width="88" height="100" rx="9" fill="#c7cdd5" stroke="#9ba2ac" stroke-width="1.5"></rect>
            <rect x="20" y="16" width="68" height="32" rx="4" fill="#262A30"></rect>
            <text data-screen data-lane="manual" x="54" y="36" text-anchor="middle" font-family="IBM Plex Mono" font-size="11" font-weight="500" fill="#7FC8A8" letter-spacing="1">READY</text>
            <circle cx="54" cy="71" r="15" fill="#b4bbc4" stroke="#9ba2ac" stroke-width="1.5"></circle>
            <circle cx="54" cy="71" r="6" fill="#3b424c"></circle>
            <rect x="22" y="98" width="64" height="6" rx="2" fill="#7c8590"></rect>
          </svg>
          <span style="font:500 8.5px 'IBM Plex Sans'; letter-spacing:.12em; text-transform:uppercase; color:#6f7a8a;">Biometer</span>
        </div>

        <div style="width:236px; flex:none; margin-right:30px;">
          <div data-bigreceipt data-lane="manual" style="width:236px; background:#f6f5f1; border:1px solid #d7d4cb; box-shadow:0 14px 32px rgba(0,0,0,.45); padding:12px 13px 13px; font-family:'IBM Plex Mono'; font-size:10px; line-height:1.5; color:#16181c; transform-origin:center;">
            <div style="display:flex; justify-content:space-between; align-items:baseline;"><span style="font-weight:600; font-size:10.5px;">NAME Carl Shen</span><span style="color:#5d6878;">:)</span></div>
            <div>MAY 25 2026&nbsp;&nbsp;9:28AM</div>
            <div>NO:51112 SN:AW7000633</div>
            <div style="border-top:1px dashed #cbc7bc; margin:5px 0;"></div>
            <div style="display:flex; justify-content:space-between;"><span style="font-weight:600;">REF.DATA</span><span>CYL:(&minus;)</span></div>
            <div>VD:<span style="color:#6b7280;">13.75</span>&nbsp;&nbsp;PD:<span data-rcpt data-lane="manual" data-key="pd" style="padding:0 1px;">59</span></div>
            <div style="display:flex;"><span style="width:26px; flex:none;">&lt;R&gt;</span><span style="width:44px; flex:none; text-align:right;">S</span><span style="width:44px; flex:none; text-align:right;">C</span><span style="width:26px; flex:none; text-align:right;">A</span></div>
            <div style="display:flex; color:#6b7280;"><span style="width:26px; flex:none;"></span><span style="width:44px; flex:none; text-align:right;">&minus;1.25</span><span style="width:44px; flex:none; text-align:right;">&minus;0.25</span><span style="width:26px; flex:none; text-align:right;">85</span></div>
            <div style="display:flex; color:#6b7280;"><span style="width:26px; flex:none;"></span><span style="width:44px; flex:none; text-align:right;">&minus;1.00</span><span style="width:44px; flex:none; text-align:right;">&minus;0.25</span><span style="width:26px; flex:none; text-align:right;">83</span></div>
            <div style="display:flex; color:#6b7280;"><span style="width:26px; flex:none;"></span><span style="width:44px; flex:none; text-align:right;">&minus;1.25</span><span style="width:44px; flex:none; text-align:right;">&minus;0.25</span><span style="width:26px; flex:none; text-align:right;">87</span></div>
            <div style="display:flex; font-weight:600;"><span style="width:26px; flex:none; color:#bf9220;">&#9656;</span><span style="width:44px; flex:none; text-align:right;"><span data-rcpt data-lane="manual" data-key="sph" style="padding:0 1px;">&minus;1.00</span></span><span style="width:44px; flex:none; text-align:right;"><span data-rcpt data-lane="manual" data-key="cyl" style="padding:0 1px;">&minus;0.25</span></span><span style="width:26px; flex:none; text-align:right;"><span data-rcpt data-lane="manual" data-key="axis" style="padding:0 1px;">85</span></span></div>
            <div style="padding-left:26px;">S.E.<span style="color:#6b7280;">&minus;1.25</span></div>
            <div style="display:flex; color:#6b7280;"><span style="width:26px; flex:none; color:#16181c;">&lt;L&gt;</span><span style="width:44px; flex:none; text-align:right;">&minus;0.50</span><span style="width:44px; flex:none; text-align:right;">&minus;0.50</span><span style="width:26px; flex:none; text-align:right;">82</span></div>
            <div style="display:flex; color:#6b7280;"><span style="width:26px; flex:none;"></span><span style="width:44px; flex:none; text-align:right;">&minus;0.50</span><span style="width:44px; flex:none; text-align:right;">&minus;0.50</span><span style="width:26px; flex:none; text-align:right;">84</span></div>
            <div style="border-top:1px dashed #cbc7bc; margin:5px 0;"></div>
            <div style="font-weight:600;">KRT.DATA</div>
            <div style="display:flex;"><span style="width:30px; flex:none;">&lt;R&gt;</span><span style="width:46px; flex:none; text-align:right;">D</span><span style="width:38px; flex:none; text-align:right;">MM</span><span style="width:26px; flex:none; text-align:right;">A</span></div>
            <div style="display:flex; color:#6b7280;"><span style="width:30px; flex:none; color:#16181c;">R1</span><span style="width:46px; flex:none; text-align:right;"><span data-rcpt data-lane="manual" data-key="k1" style="padding:0 1px;">44.00</span></span><span style="width:38px; flex:none; text-align:right;">7.67</span><span style="width:26px; flex:none; text-align:right;">101</span></div>
            <div style="display:flex; color:#6b7280;"><span style="width:30px; flex:none; color:#16181c;">R2</span><span style="width:46px; flex:none; text-align:right;"><span data-rcpt data-lane="manual" data-key="k2" style="padding:0 1px;">45.50</span></span><span style="width:38px; flex:none; text-align:right;">7.43</span><span style="width:26px; flex:none; text-align:right;">11</span></div>
            <div style="display:flex; color:#6b7280;"><span style="width:30px; flex:none; color:#16181c;">AVG</span><span style="width:46px; flex:none; text-align:right;">44.75</span><span style="width:38px; flex:none; text-align:right;">7.55</span><span style="width:26px; flex:none; text-align:right;"></span></div>
            <div style="padding-left:30px;">R1&minus;R2:<span style="color:#6b7280;">&minus;1.50</span></div>
            <div style="display:flex; color:#6b7280;"><span style="width:30px; flex:none; color:#16181c;">&lt;L&gt;</span><span style="width:46px; flex:none; text-align:right;">44.00</span><span style="width:38px; flex:none; text-align:right;">7.68</span><span style="width:26px; flex:none; text-align:right;">71</span></div>
            <div style="display:flex; color:#6b7280;"><span style="width:30px; flex:none;"></span><span style="width:46px; flex:none; text-align:right;">45.00</span><span style="width:38px; flex:none; text-align:right;">7.50</span><span style="width:26px; flex:none; text-align:right;">161</span></div>
            <div style="border-top:1px dashed #cbc7bc; margin:5px 0;"></div>
            <div style="display:flex; justify-content:space-between;"><span style="font-weight:600;">TONO.DATA</span><span>mmHg AVG</span></div>
            <div style="display:flex; color:#6b7280;"><span style="width:24px; flex:none; color:#16181c;">R</span><span style="width:40px; flex:none; text-align:right;">14</span><span style="width:40px; flex:none; text-align:right;">15</span><span style="width:42px; flex:none; text-align:right;"><span data-rcpt data-lane="manual" data-key="iop" style="padding:0 1px;">16</span></span></div>
            <div style="display:flex; color:#6b7280;"><span style="width:24px; flex:none; color:#16181c;">L</span><span style="width:40px; flex:none; text-align:right;">(15)</span><span style="width:40px; flex:none; text-align:right;">16</span><span style="width:42px; flex:none; text-align:right;">16</span></div>
            <div style="display:flex; justify-content:space-between; margin-top:2px;"><span style="font-weight:600;">PACH.DATA</span><span>&micro;m AVG</span></div>
            <div style="display:flex; color:#6b7280;"><span style="width:24px; flex:none; color:#16181c;">R</span><span style="width:40px; flex:none; text-align:right;">495</span><span style="width:40px; flex:none; text-align:right;">498</span><span style="width:42px; flex:none; text-align:right;"><span data-rcpt data-lane="manual" data-key="cct" style="padding:0 1px;">497</span></span></div>
            <div style="display:flex; color:#6b7280;"><span style="width:24px; flex:none; color:#16181c;">L</span><span style="width:40px; flex:none; text-align:right;">505</span><span style="width:40px; flex:none; text-align:right;">500</span><span style="width:42px; flex:none; text-align:right;">502</span></div>
            <div style="border-top:1px dashed #cbc7bc; margin:5px 0;"></div>
            <div style="text-align:right; font-weight:600; letter-spacing:1px;">TOPCON</div>
          </div>
        </div>

        <div data-paper data-lane="manual" style="position:absolute; left:14px; top:24px; width:120px; background:#f6f5f1; border:1px solid #d7d4cb; box-shadow:0 6px 16px rgba(0,0,0,.4); padding:8px 9px 12px; transform-origin:center; opacity:0; z-index:7;">
          <div style="height:5px; background:#52555c; border-radius:1px; width:70%; margin-bottom:5px;"></div>
          <div style="height:3px; background:#c5c2b8; border-radius:1px; width:90%; margin-bottom:4px;"></div>
          <div style="height:3px; background:#c5c2b8; border-radius:1px; width:55%; margin-bottom:7px;"></div>
          <div style="height:3px; background:#c5c2b8; border-radius:1px; width:60%; margin-bottom:4px;"></div>
          <div style="height:3px; background:#c5c2b8; border-radius:1px; width:85%; margin-bottom:4px;"></div>
          <div style="height:3px; background:#c5c2b8; border-radius:1px; width:78%; margin-bottom:4px;"></div>
          <div style="height:3px; background:#c5c2b8; border-radius:1px; width:88%; margin-bottom:7px;"></div>
          <div style="height:3px; background:#c5c2b8; border-radius:1px; width:50%; margin-bottom:4px;"></div>
          <div style="height:3px; background:#c5c2b8; border-radius:1px; width:82%; margin-bottom:4px;"></div>
          <div style="height:3px; background:#c5c2b8; border-radius:1px; width:90%; margin-bottom:4px;"></div>
          <div style="height:3px; background:#c5c2b8; border-radius:1px; width:64%; margin-bottom:7px;"></div>
          <div style="height:3px; background:#c5c2b8; border-radius:1px; width:58%; margin-bottom:4px;"></div>
          <div style="height:3px; background:#c5c2b8; border-radius:1px; width:86%; margin-bottom:4px;"></div>
          <div style="height:3px; background:#c5c2b8; border-radius:1px; width:72%; margin-bottom:4px;"></div>
          <div style="height:3px; background:#c5c2b8; border-radius:1px; width:80%;"></div>
        </div>

        <div style="flex:none; width:412px; margin-left:auto; align-self:center;">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:10px;">
            <span style="font:600 10px 'IBM Plex Sans'; letter-spacing:.09em; text-transform:uppercase; color:#7e8a9a;">EMR &middot; OD Encounter</span>
            <span data-formstatus data-lane="manual" style="font:500 9px 'IBM Plex Mono'; color:#5d6878;">0 / 8 filled</span>
          </div>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px 14px;">
            <div style="display:flex; flex-direction:column; gap:4px;"><span style="font:500 9.5px 'IBM Plex Sans'; letter-spacing:.05em; text-transform:uppercase; color:#7e8a9a;">Sphere (OD)</span><div data-emr data-lane="manual" data-key="sph" style="position:relative; height:31px; border:1px solid #4a5260; border-radius:5px; background:#0c0f14; display:flex; align-items:center; padding:0 9px; font:500 13px/1 'IBM Plex Mono'; color:#e7ecf3;"><span data-val></span><span data-caret style="display:inline-block; width:1.5px; height:15px; background:#e7ecf3; margin-left:1px;"></span><span style="margin-left:auto; font:400 10px 'IBM Plex Sans'; color:#5d6878;">D</span></div></div>
            <div style="display:flex; flex-direction:column; gap:4px;"><span style="font:500 9.5px 'IBM Plex Sans'; letter-spacing:.05em; text-transform:uppercase; color:#7e8a9a;">Cylinder (OD)</span><div data-emr data-lane="manual" data-key="cyl" style="position:relative; height:31px; border:1px solid #4a5260; border-radius:5px; background:#0c0f14; display:flex; align-items:center; padding:0 9px; font:500 13px/1 'IBM Plex Mono'; color:#e7ecf3;"><span data-val></span><span data-caret style="display:inline-block; width:1.5px; height:15px; background:#e7ecf3; margin-left:1px;"></span><span style="margin-left:auto; font:400 10px 'IBM Plex Sans'; color:#5d6878;">D</span></div></div>
            <div style="display:flex; flex-direction:column; gap:4px;"><span style="font:500 9.5px 'IBM Plex Sans'; letter-spacing:.05em; text-transform:uppercase; color:#7e8a9a;">Axis (OD)</span><div data-emr data-lane="manual" data-key="axis" style="position:relative; height:31px; border:1px solid #4a5260; border-radius:5px; background:#0c0f14; display:flex; align-items:center; padding:0 9px; font:500 13px/1 'IBM Plex Mono'; color:#e7ecf3;"><span data-val></span><span data-caret style="display:inline-block; width:1.5px; height:15px; background:#e7ecf3; margin-left:1px;"></span><span style="margin-left:auto; font:400 10px 'IBM Plex Sans'; color:#5d6878;">&deg;</span></div></div>
            <div style="display:flex; flex-direction:column; gap:4px;"><span style="font:500 9.5px 'IBM Plex Sans'; letter-spacing:.05em; text-transform:uppercase; color:#7e8a9a;">PD</span><div data-emr data-lane="manual" data-key="pd" style="position:relative; height:31px; border:1px solid #4a5260; border-radius:5px; background:#0c0f14; display:flex; align-items:center; padding:0 9px; font:500 13px/1 'IBM Plex Mono'; color:#e7ecf3;"><span data-val></span><span data-caret style="display:inline-block; width:1.5px; height:15px; background:#e7ecf3; margin-left:1px;"></span><span style="margin-left:auto; font:400 10px 'IBM Plex Sans'; color:#5d6878;">mm</span></div></div>
            <div style="display:flex; flex-direction:column; gap:4px;"><span style="font:500 9.5px 'IBM Plex Sans'; letter-spacing:.05em; text-transform:uppercase; color:#7e8a9a;">K1 (OD)</span><div data-emr data-lane="manual" data-key="k1" style="position:relative; height:31px; border:1px solid #4a5260; border-radius:5px; background:#0c0f14; display:flex; align-items:center; padding:0 9px; font:500 13px/1 'IBM Plex Mono'; color:#e7ecf3;"><span data-val></span><span data-caret style="display:inline-block; width:1.5px; height:15px; background:#e7ecf3; margin-left:1px;"></span><span style="margin-left:auto; font:400 10px 'IBM Plex Sans'; color:#5d6878;">D</span></div></div>
            <div style="display:flex; flex-direction:column; gap:4px;"><span style="font:500 9.5px 'IBM Plex Sans'; letter-spacing:.05em; text-transform:uppercase; color:#7e8a9a;">K2 (OD)</span><div data-emr data-lane="manual" data-key="k2" style="position:relative; height:31px; border:1px solid #4a5260; border-radius:5px; background:#0c0f14; display:flex; align-items:center; padding:0 9px; font:500 13px/1 'IBM Plex Mono'; color:#e7ecf3;"><span data-val></span><span data-caret style="display:inline-block; width:1.5px; height:15px; background:#e7ecf3; margin-left:1px;"></span><span style="margin-left:auto; font:400 10px 'IBM Plex Sans'; color:#5d6878;">D</span></div></div>
            <div style="display:flex; flex-direction:column; gap:4px;"><span style="font:500 9.5px 'IBM Plex Sans'; letter-spacing:.05em; text-transform:uppercase; color:#7e8a9a;">IOP (OD)</span><div data-emr data-lane="manual" data-key="iop" style="position:relative; height:31px; border:1px solid #4a5260; border-radius:5px; background:#0c0f14; display:flex; align-items:center; padding:0 9px; font:500 13px/1 'IBM Plex Mono'; color:#e7ecf3;"><span data-val></span><span data-caret style="display:inline-block; width:1.5px; height:15px; background:#e7ecf3; margin-left:1px;"></span><span style="margin-left:auto; font:400 10px 'IBM Plex Sans'; color:#5d6878;">mmHg</span></div></div>
            <div style="display:flex; flex-direction:column; gap:4px;"><span style="font:500 9.5px 'IBM Plex Sans'; letter-spacing:.05em; text-transform:uppercase; color:#7e8a9a;">CCT (OD)</span><div data-emr data-lane="manual" data-key="cct" style="position:relative; height:31px; border:1px solid #4a5260; border-radius:5px; background:#0c0f14; display:flex; align-items:center; padding:0 9px; font:500 13px/1 'IBM Plex Mono'; color:#e7ecf3;"><span data-val></span><span data-caret style="display:inline-block; width:1.5px; height:15px; background:#e7ecf3; margin-left:1px;"></span><span style="margin-left:auto; font:400 10px 'IBM Plex Sans'; color:#5d6878;">&micro;m</span></div></div>
          </div>
        </div>

        <svg data-overlay data-lane="manual" style="position:absolute; inset:0; width:100%; height:100%; overflow:visible; pointer-events:none; z-index:4;">
          <defs><marker id="ah-manual" markerWidth="8" markerHeight="8" refX="5.5" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill="#6B7B92"></path></marker></defs>
          <g data-arrows></g>
        </svg>
        <div data-cursor data-lane="manual" style="position:absolute; left:0; top:0; width:22px; height:22px; z-index:8; pointer-events:none;">
          <svg width="22" height="22" viewBox="0 0 22 22"><path d="M2,2 L2,17 L6.4,13 L9.6,19.5 L12.4,18.3 L9.2,11.9 L15,11.9 Z" fill="#dbe2ea" stroke="#fff" stroke-width="1.1"></path></svg>
        </div>
      </div>

      <div data-lanescrim data-lane="manual" style="position:absolute; inset:0; background:rgba(251,251,249,0.45); backdrop-filter:blur(3px); -webkit-backdrop-filter:blur(3px); border-radius:10px; opacity:0; display:none; z-index:20;"></div>
      <svg data-lanearrows data-lane="manual" style="position:absolute; inset:0; width:100%; height:100%; overflow:visible; pointer-events:none; z-index:22;"><defs><marker id="ah-pop-manual" markerWidth="8" markerHeight="8" refX="5.5" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill="#6B7B92"></path></marker></defs><g data-poparrows></g></svg>
      <div data-lanepop data-lane="manual" style="position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); z-index:23; opacity:0; display:none;"></div>
    </div>

    <!-- ================= WATCHER LANE ================= -->
    <div data-lanecard data-lane="watcher" style="position:relative; background:#161b22; border:1px solid #272e39; border-radius:10px; padding:15px 18px 18px; box-shadow:0 1px 0 rgba(0,0,0,.02);">
