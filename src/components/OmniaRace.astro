<script is:inline>
  (function () {
    const root = document.querySelector('.emr-root');
    if (!root) return;
    const intro = root.closest('[data-bench-scene]')?.querySelector('[data-intro]');
    const progWrap = root.closest('[data-bench-scene]')?.querySelector('[data-prog]');
    const progFill = progWrap?.querySelector('.sp-fill');
    const setProg = (p) => { if (progFill) progFill.style.width = (Math.max(0, Math.min(1, p)) * 100).toFixed(2) + '%'; };

    class EMRRace {
      constructor(root) {
        this.root = root;
        this.runId = 0;
        this.PROPS = { errorCount: 4, manualPaceMs: 88, timeCompression: 4 };
        this.FIELDS = [
          { key:'sph', value:'-1.00' }, { key:'cyl', value:'-0.25' }, { key:'axis', value:'85' },
          { key:'pd', value:'59' }, { key:'k1', value:'44.00' }, { key:'k2', value:'45.50' },
          { key:'iop', value:'16' }, { key:'cct', value:'497' },
        ];
        this.scale = 1;
        this.reset();
        const s = this.q('[data-start]'); if (s) s.addEventListener('click', () => this.start());
        const r = this.q('[data-reset]'); if (r) r.addEventListener('click', () => this.reset());
        this.fit();
        addEventListener('resize', () => this.fit(), { passive: true });
        if (document.fonts && document.fonts.ready) document.fonts.ready.then(() => this.fit());
      }
      // scale the whole widget to fit the viewport (so the pinned section shows it
      // all at once). relTo()/movePaper divide rect math by this.scale so the SVG
      // arrows stay aligned under the transform.
      fit() {
        this.root.style.position = ''; this.root.style.left = ''; this.root.style.top = ''; this.root.style.width = '';
        this.root.style.transform = 'none';
        const inner = this.root.querySelector('.emr-inner');
        const h = this.root.offsetHeight;
        const cw = inner ? inner.scrollWidth + 60 : this.root.offsetWidth;
        const pinned = window.matchMedia('(min-width:761px)').matches;
        if (!pinned) {
          // mobile: pin the width to the content (the root is otherwise fluid, unlike the
          // other two scenes), then scale to fit width + absolutely centre + clip via
          // .bench-scene. relTo()/movePaper divide rect math by this.scale, so the SVG
          // arrows stay aligned (the translate offset cancels in relTo() differences).
          const s = Math.min(1, (window.innerWidth - 8) / cw);
          this.scale = s;
          this.root.style.width = cw + 'px';
          this.root.style.transformOrigin = '50% 50%';
          this.root.style.position = 'absolute'; this.root.style.left = '50%'; this.root.style.top = '50%';
          this.root.style.transform = `translate(-50%,-50%) scale(${s.toFixed(4)})`;
          return;
        }
        // reserve a top strip for the bench slider tabs (desktop) so they don't overlap
        const RES = 88;
        const s = Math.min(1, (window.innerHeight - 18 - RES) / h, (window.innerWidth - 12) / cw);
        this.scale = s;
        // origin top so the scaled visual starts at the root's layout top; translateY
        // centres it in the viewport. (translateY cancels in relTo() differences.)
        const ty = RES + Math.max(0, (window.innerHeight - RES - h * s) / 2);
        this.root.style.transformOrigin = 'top center';
        this.root.style.transform = `translateY(${ty.toFixed(1)}px) scale(${s.toFixed(4)})`;
      }
      clearTimers() {}
      ease(p) { return 1 - Math.pow(1 - p, 3); }
      tween(dur, fn, done) {
        const id = this.runId, t0 = performance.now();
        const step = (now) => {
          if (this.runId !== id) return;
          let p = Math.min(1, (now - t0) / dur);
          fn(p);
          if (p < 1) requestAnimationFrame(step); else if (done) done();
        };
        requestAnimationFrame(step);
      }
      q(sel) { return this.root ? this.root.querySelector(sel) : null; }
      qa(sel) { return this.root ? Array.from(this.root.querySelectorAll(sel)) : []; }
      sleep(ms) { return new Promise(r => setTimeout(r, ms)); }
      pad(n) { return String(n).padStart(2, '0'); }
      fmt(sec) { sec = Math.max(0, sec); const m=Math.floor(sec/60), s=Math.floor(sec%60), cs=Math.floor((sec*100)%100); return `${this.pad(m)}:${this.pad(s)}.${this.pad(cs)}`; }
      fmtMS(sec) { sec = Math.max(0, sec); return `${this.pad(Math.floor(sec/60))}:${this.pad(Math.floor(sec%60))}`; }
      bodyEl(lane) { return this.q(`[data-body][data-lane="${lane}"]`); }
      emr(lane, key) { return this.q(`[data-emr][data-lane="${lane}"][data-key="${key}"]`); }
      rcptVal(lane, key) { return this.q(`[data-rcpt][data-lane="${lane}"][data-key="${key}"]`); }
      relTo(ref, el) {
        const z = this.scale || 1;
        const br = ref.getBoundingClientRect(), r = el.getBoundingClientRect();
        return { l:(r.left-br.left)/z, t:(r.top-br.top)/z, r:(r.right-br.left)/z, b:(r.bottom-br.top)/z, cx:((r.left+r.right)/2-br.left)/z, cy:((r.top+r.bottom)/2-br.top)/z, w:r.width/z, h:r.height/z };
      }
      rel(lane, el) { return this.relTo(this.bodyEl(lane), el); }
      setClock(lane, sec) { const el = this.q(`[data-clock][data-lane="${lane}"]`); if (el) el.textContent = this.fmt(sec); }
      setActions(lane, n) { this.actions[lane]=n; const el=this.q(`[data-actions][data-lane="${lane}"]`); if(el) el.textContent=n; }
      bump(lane) { this.setActions(lane, this.actions[lane]+1); }
      incErr(lane) { this.errors[lane]++; const el=this.q(`[data-errors][data-lane="${lane}"]`); if(el){ el.textContent=this.errors[lane]; el.style.color='#e8705f'; } }
      setStatus(lane, n) { const el=this.q(`[data-formstatus][data-lane="${lane}"]`); if(el) el.textContent = lane==='watcher'&&n===8 ? '8 / 8 · parsed' : `${n} / 8 filled`; }
      flash(box, type) {
        const color = type === 'ok' ? 'rgba(46,158,107,.95)' : 'rgba(214,69,69,.95)';
        const rest = (box === this.activeBox) ? '0 0 0 2px rgba(107,123,146,.16)' : 'none';
        box.style.boxShadow = `0 0 0 2.5px ${color}`;
        box.style.borderColor = type === 'ok' ? '#5fc88f' : '#e8705f';
        setTimeout(() => { box.style.boxShadow = rest; box.style.borderColor = (box === this.activeBox) ? '#6B7B92' : '#4a5260'; }, 320);
      }
      highlight(span, type) {
        if (!span) return;
        if (type === 'ok') { span.style.background = '#163524'; span.style.color = '#5fc88f'; }
        else { span.style.background = '#ffe26b'; span.style.color = '#3a2e00'; }
        span.style.borderRadius = '3px';
      }
      drawArrowG(g, marker, sx, sy, ex, ey, opts) {
        const ns = 'http://www.w3.org/2000/svg';
        const p = document.createElementNS(ns, 'path');
        const bow = opts.bow || 0;
        const dx = Math.max(40, Math.abs(ex - sx) * 0.4);
        let d;
        if (opts.vertical) d = `M${sx},${sy} C${sx + bow},${sy + (ey-sy)*0.4} ${ex + bow},${ey - (ey-sy)*0.4} ${ex},${ey}`;
        else d = `M${sx},${sy} C${sx+dx},${sy} ${ex-dx},${ey} ${ex},${ey}`;
        p.setAttribute('d', d);
        p.setAttribute('fill', 'none');
        p.setAttribute('stroke', opts.color);
        p.setAttribute('stroke-width', opts.w);
        p.setAttribute('stroke-linecap', 'round');
        if (marker) p.setAttribute('marker-end', `url(#${marker})`);
        g.appendChild(p);
        return p;
      }
      drawArrow(lane, sx, sy, ex, ey, opts) {
        const g = this.q(`[data-overlay][data-lane="${lane}"] [data-arrows]`);
        return this.drawArrowG(g, `ah-${lane}`, sx, sy, ex, ey, opts);
      }
      drawIn(p, dur) {
        const len = p.getTotalLength();
        p.style.strokeDasharray = len; p.style.strokeDashoffset = len;
        this.tween(dur || 300, t => { p.style.strokeDashoffset = String(len * (1 - this.ease(t))); }, () => { p.style.strokeDashoffset = '0'; });
        return len;
      }
      fadeRemove(p, delay, dur) {
        setTimeout(() => { this.tween(dur || 280, t => { p.style.opacity = String(1 - t); }, () => p.remove()); }, delay || 0);
      }

      reset() {
        this.runId++;
        this.active = false;
        setProg(0); if (progWrap) progWrap.classList.remove('on');
        this.activeBox = null;
        this.cursorPos = { x:-60, y:-60 };
        this.clearTimers();
        this.actions = { manual:0, watcher:0 };
        this.errors  = { manual:0, watcher:0 };
        this.manualRunning = false; this.watcherRunning = false;
        this.manualDisplay = 0; this.manualFinalSec = 0; this.watcherFinalSec = 0.42;

        ['manual','watcher'].forEach(lane => {
          this.setClock(lane, 0);
          const a = this.q(`[data-actions][data-lane="${lane}"]`); if (a) a.textContent = '0';
          const e = this.q(`[data-errors][data-lane="${lane}"]`); if (e) { e.textContent = '0'; e.style.color = '#dbe2ea'; }
          this.setStatus(lane, 0);
          const sc = this.q(`[data-screen][data-lane="${lane}"]`); if (sc) sc.textContent = 'READY';
          this.qa(`[data-emr][data-lane="${lane}"]`).forEach(box => {
            const v = box.querySelector('[data-val]'); if (v) { v.textContent = ''; v.style.color = ''; }
            const c = box.querySelector('[data-caret]'); if (c) { c.style.opacity='0'; c.style.animation='none'; }
            box.style.borderColor = '#4a5260'; box.style.boxShadow = 'none';
          });
          const g = this.q(`[data-overlay][data-lane="${lane}"] [data-arrows]`); if (g) g.innerHTML = '';
          const pg = this.q(`[data-lanearrows][data-lane="${lane}"] [data-poparrows]`); if (pg) pg.innerHTML = '';
          const scrim = this.q(`[data-lanescrim][data-lane="${lane}"]`); if (scrim) { scrim.style.display='none'; scrim.style.opacity='0'; scrim.style.pointerEvents='none'; }
          const pop = this.q(`[data-lanepop][data-lane="${lane}"]`); if (pop) { pop.style.display='none'; pop.style.opacity='0'; pop.innerHTML=''; }
          this.dimLane(lane, false);
        });

        // manual receipt values read as dark-grey numbers (labels stay black); watcher xml keeps its own light ink
        this.qa('[data-rcpt]').forEach(s => { s.style.background = 'transparent'; s.style.color = s.getAttribute('data-lane') === 'manual' ? '#6b7280' : ''; });

        const big = this.q('[data-bigreceipt][data-lane="manual"]');
        if (big) { big.style.opacity = '0'; big.style.transform = 'scale(0.96)'; }
        const paper = this.q('[data-paper][data-lane="manual"]');
        if (paper) { paper.style.opacity = '0'; paper.style.transform = 'translate(0px,-46px) scale(0.55)'; paper.style.filter = 'blur(3.5px)'; }
        const dig = this.q('[data-digital][data-lane="watcher"]');
        if (dig) { dig.style.opacity = '0'; dig.style.transform = 'translateY(14px) scale(0.94)'; }
        const tag = this.q('[data-digtag]'); if (tag) { tag.textContent = 'queued'; tag.style.color = '#7d8a98'; }

        this.qa('[data-fx]').forEach(n => n.remove());
        const cur = this.q('[data-cursor][data-lane="manual"]');
        if (cur) { cur.style.opacity = '0'; cur.style.transform = 'translate(-60px,-60px)'; }

        const res = this.q('[data-results]'); if (res) res.style.opacity = '0';
        const cg = this.q('[data-comp-arrows]'); if (cg) cg.innerHTML = '';
        const start = this.q('[data-start]');
        if (start) { start.disabled = false; start.style.opacity = '1'; start.style.cursor = 'pointer'; start.textContent = 'Start race'; }
      }

      start() {
        this.reset();
        const id = ++this.runId;
        this.active = true;
        const start = this.q('[data-start]');
        if (start) { start.disabled = true; start.style.opacity = '.5'; start.style.cursor = 'default'; start.textContent = 'Running…'; }
        this.errorCount = Math.max(0, Math.min(this.FIELDS.length, this.PROPS.errorCount));
        this.paceMs     = this.PROPS.manualPaceMs;
        this.COMPRESS   = this.PROPS.timeCompression;
        // time-based progress bar (the race is an async sequence; estimate the total and
        // snap to 100% at the comparison). gives a rough "how long is left" read.
        if (progWrap) progWrap.classList.add('on');
        this._progDone = false;
        const EST = 30000, pT0 = performance.now();
        const progStep = () => {
          if (this.runId !== id || this._progDone) return;
          setProg(Math.min(0.96, (performance.now() - pT0) / EST));
          requestAnimationFrame(progStep);
        };
        requestAnimationFrame(progStep);
        this.runSequence(id);
      }

      async runSequence(id) {
        await this.runManual(id);                    if (this.runId !== id) return;
        await this.sleep(450);                        if (this.runId !== id) return;
        await this.showLaneSpotlight(id, 'manual');   if (this.runId !== id) return;
        await this.runWatcher(id);                    if (this.runId !== id) return;
        await this.sleep(2000);                       if (this.runId !== id) return;  // beat to digest the filled form before metrics pop
        await this.showLaneSpotlight(id, 'watcher');  if (this.runId !== id) return;
        await this.showComparison(id);
      }

      startLaneClock(lane, id) {
        const t0 = performance.now();
        this[lane + 'Running'] = true;
        const step = (now) => {
          if (this.runId !== id || !this[lane + 'Running']) return;
          const e = (now - t0) / 1000;
          if (lane === 'manual') { this.manualDisplay = e * this.COMPRESS; this.setClock('manual', this.manualDisplay); }
          else { const w = Math.min(e, 0.42); this.setClock('watcher', w); if (e >= 0.42) { this.watcherRunning = false; this.setClock('watcher', 0.42); return; } }
          requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      }
      freezeLane(lane) { this[lane + 'Running'] = false; if (lane === 'manual') this.manualFinalSec = this.manualDisplay; }

      dimLane(lane, on, level) {
        const card = this.q(`[data-lanecard][data-lane="${lane}"]`);
        if (card) { card.style.opacity = on ? (level || '0.4') : '1'; card.style.filter = on ? 'saturate(.6)' : 'none'; }
      }
      scrollToLane() {}   // no-op: the widget lives inside the page's own scroll

      extrudePaper(id) {
        return new Promise(resolve => {
          const sc = this.q('[data-screen][data-lane="manual"]'); if (sc) sc.textContent = 'PRINT';
          const paper = this.q('[data-paper][data-lane="manual"]');
          if (!paper) { resolve(); return; }
          this.tween(1000, p => {
            const e = this.ease(p);
            paper.style.transform = `translate(0px,${(-46 + 46 * e).toFixed(1)}px) scale(0.55)`;
            paper.style.opacity = String(Math.min(1, e * 1.6));
            paper.style.filter = 'blur(3.5px)';
          }, () => { paper.style.transform = 'translate(0px,0px) scale(0.55)'; paper.style.opacity = '1'; resolve(); });
        });
      }
      cutPaper(id) {
        return new Promise(resolve => {
          const sc = this.q('[data-screen][data-lane="manual"]'); if (sc) sc.textContent = 'CUT';
          const body = this.bodyEl('manual');
          const paper = this.q('[data-paper][data-lane="manual"]');
          const pr = this.rel('manual', paper);
          const line = document.createElement('div'); line.setAttribute('data-fx','');
          line.style.cssText = `position:absolute; left:${(pr.l-7).toFixed(0)}px; top:${(pr.t+5).toFixed(0)}px; width:${(pr.w+14).toFixed(0)}px; height:0; border-top:2px dashed #C06A5C; z-index:9; pointer-events:none;`;
          body.appendChild(line);
          const sciss = document.createElement('div'); sciss.setAttribute('data-fx','');
          sciss.style.cssText = `position:absolute; left:${(pr.l-12).toFixed(0)}px; top:${(pr.t).toFixed(0)}px; width:0; height:0; border-top:6px solid transparent; border-bottom:6px solid transparent; border-left:10px solid #C06A5C; z-index:10; pointer-events:none;`;
          body.appendChild(sciss);
          this.tween(440, t => { sciss.style.transform = `translateX(${((pr.w + 16) * t).toFixed(1)}px)`; }, () => {});
          setTimeout(() => { line.remove(); sciss.remove(); resolve(); }, 500);
        });
      }
      movePaper(id) {
        return new Promise(resolve => {
          const sc = this.q('[data-screen][data-lane="manual"]'); if (sc) sc.textContent = 'SCAN';
          const paper = this.q('[data-paper][data-lane="manual"]');
          const big = this.q('[data-bigreceipt][data-lane="manual"]');
          if (!paper || !big) { resolve(); return; }
          const z = this.scale || 1;
          const pr = paper.getBoundingClientRect(), br = big.getBoundingClientRect();
          const dcx = ((br.left + br.right) / 2 - (pr.left + pr.right) / 2) / z;
          const dcy = ((br.top + br.bottom) / 2 - (pr.top + pr.bottom) / 2) / z;
          this.tween(1050, p => {
            const e = this.ease(p);
            const s = 0.55 + (1.55 - 0.55) * e;
            paper.style.transform = `translate(${(dcx*e).toFixed(1)}px,${(dcy*e).toFixed(1)}px) scale(${s.toFixed(3)})`;
            paper.style.filter = `blur(${(3.5 * (1 - e)).toFixed(2)}px)`;
          }, () => resolve());
        });
      }
      clarifyReceipt(id) {
        return new Promise(resolve => {
          const sc = this.q('[data-screen][data-lane="manual"]'); if (sc) sc.textContent = 'READ';
          const paper = this.q('[data-paper][data-lane="manual"]');
          const big = this.q('[data-bigreceipt][data-lane="manual"]');
          if (!big) { resolve(); return; }
          this.tween(440, p => {
            const e = this.ease(p);
            big.style.opacity = String(e); big.style.transform = `scale(${(0.96 + 0.04 * e).toFixed(3)})`;
            if (paper) paper.style.opacity = String(1 - e);
          }, () => { big.style.opacity = '1'; big.style.transform = 'scale(1)'; if (paper) paper.style.opacity = '0'; resolve(); });
        });
      }
      animateCursor(x, y, dur) {
        const c = this.q('[data-cursor][data-lane="manual"]');
        if (!c) return Promise.resolve();
        c.style.opacity = '1';
        const from = this.cursorPos || { x, y };
        return new Promise(resolve => {
          this.tween(dur || 280, p => {
            const e = this.ease(p);
            const cx = from.x + (x - from.x) * e, cy = from.y + (y - from.y) * e;
            c.style.transform = `translate(${(cx-2).toFixed(1)}px,${(cy-3).toFixed(1)}px)`;
            this.cursorPos = { x:cx, y:cy };
          }, () => { this.cursorPos = { x, y }; resolve(); });
        });
      }
      activate(box) {
        this.activeBox = box;
        box.style.borderColor = '#6B7B92'; box.style.boxShadow = '0 0 0 2px rgba(107,123,146,.16)';
        const c = box.querySelector('[data-caret]'); if (c) { c.style.opacity='1'; c.style.animation='caretBlink 1s steps(1) infinite'; }
      }
      deactivate(box) {
        if (this.activeBox === box) this.activeBox = null;
        box.style.borderColor = '#4a5260'; box.style.boxShadow = 'none';
        const c = box.querySelector('[data-caret]'); if (c) { c.style.opacity='0'; c.style.animation='none'; }
      }
      wrongChar(ch) {
        if (/[0-9]/.test(ch)) { let d; do { d = String(Math.floor(Math.random()*10)); } while (d === ch); return d; }
        if (ch === '.') return '8'; if (ch === '-') return '7'; return '0';
      }

      async runManual(id) {
        this.dimLane('watcher', true); this.scrollToLane('manual');
        this.startLaneClock('manual', id);
        await this.extrudePaper(id); if (this.runId !== id) return;
        await this.sleep(180); if (this.runId !== id) return;
        await this.cutPaper(id); if (this.runId !== id) return;
        await this.movePaper(id); if (this.runId !== id) return;
        await this.clarifyReceipt(id); if (this.runId !== id) return;
        await this.sleep(280); if (this.runId !== id) return;

        const errIdx = new Set();
        const pool = [0,1,2,3,4,5,6,7];
        while (errIdx.size < this.errorCount) errIdx.add(pool.splice(Math.floor(Math.random()*pool.length),1)[0]);

        let filled = 0;
        for (let i = 0; i < this.FIELDS.length; i++) {
          if (this.runId !== id) return;
          const f = this.FIELDS[i];
          const rval = this.rcptVal('manual', f.key);
          const box  = this.emr('manual', f.key);
          const valEl = box.querySelector('[data-val]');

          let rp = this.rel('manual', rval);
          await this.animateCursor(rp.r + 3, rp.cy, 270); if (this.runId !== id) return;
          await this.sleep(150); if (this.runId !== id) return;
          this.highlight(rval, 'read');
          await this.sleep(150); if (this.runId !== id) return;

          let bp = this.rel('manual', box);
          // park the cursor at the field's right edge so it never covers the digits,
          // which type in from the left (otherwise the entry is hidden under the pointer)
          await this.animateCursor(bp.r - 18, bp.b - 7, 250); if (this.runId !== id) return;

          rp = this.rel('manual', rval); bp = this.rel('manual', box);
          const p = this.drawArrow('manual', rp.r, rp.cy, bp.l, bp.cy, { color:'#6B7B92', w:1.6 });
          this.drawIn(p, 250);

          this.activate(box); this.bump('manual');
          if (errIdx.has(i)) await this.typeWithError(id, box, valEl, f.value);
          else await this.typeClean(id, box, valEl, f.value);
          if (this.runId !== id) return;
          this.deactivate(box);
          filled++; this.setStatus('manual', filled);
          await this.sleep(140); if (this.runId !== id) return;
        }
        const cur = this.q('[data-cursor][data-lane="manual"]'); if (cur) cur.style.opacity = '0';
        this.freezeLane('manual');
      }

      async typeClean(id, box, valEl, value) {
        for (const ch of value) { if (this.runId !== id) return; valEl.textContent += ch; this.bump('manual'); await this.sleep(this.paceMs + Math.random()*55); }
      }
      async typeWithError(id, box, valEl, value) {
        const errAt = 1 + Math.floor(Math.random() * (value.length - 1));
        for (let k = 0; k < errAt; k++) { if (this.runId !== id) return; valEl.textContent += value[k]; this.bump('manual'); await this.sleep(this.paceMs + Math.random()*55); }
        valEl.textContent += this.wrongChar(value[errAt]); this.bump('manual');
        valEl.style.color = '#e8705f'; this.incErr('manual');   // flag the wrong number red, not the field box
        await this.sleep(this.paceMs + 50); await this.sleep(440); if (this.runId !== id) return;
        while (valEl.textContent.length > 0) { if (this.runId !== id) return; valEl.textContent = valEl.textContent.slice(0,-1); this.bump('manual'); await this.sleep(45); }
        valEl.style.color = '';   // corrected entry types back in normal ink
        await this.sleep(150); if (this.runId !== id) return;
        for (const ch of value) { if (this.runId !== id) return; valEl.textContent += ch; this.bump('manual'); await this.sleep(this.paceMs + Math.random()*55); }
      }

      uploadDigital(id) {
        return new Promise(resolve => {
          const sc = this.q('[data-screen][data-lane="watcher"]'); if (sc) sc.textContent = 'UPLOAD';
          const b = this.bodyEl('watcher');
          const m = this.rel('watcher', this.q('[data-machine][data-lane="watcher"]'));
          const x = m.cx, y0 = m.t + 8;
          for (let i = 0; i < 4; i++) {
            setTimeout(() => {
              if (this.runId !== id) return;
              const ch = document.createElement('div'); ch.setAttribute('data-fx','');
              ch.style.cssText = `position:absolute; left:${(x-6).toFixed(0)}px; top:${y0.toFixed(0)}px; width:0; height:0; border-left:6px solid transparent; border-right:6px solid transparent; border-bottom:9px solid #F76B54; pointer-events:none; z-index:6;`;
              b.appendChild(ch);
              this.tween(560, p => { ch.style.transform = `translateY(${(-52*p).toFixed(1)}px)`; ch.style.opacity = String(Math.max(0, 1-p)); }, () => ch.remove());
            }, i * 110);
          }
          setTimeout(resolve, 740);
        });
      }
      revealBrowser(id) {
        return new Promise(resolve => {
          const sc = this.q('[data-screen][data-lane="watcher"]'); if (sc) sc.textContent = 'ONLINE';
          const tag = this.q('[data-digtag]'); if (tag) { tag.textContent = '200 OK'; tag.style.color = '#5fc88f'; }
          const d = this.q('[data-digital][data-lane="watcher"]');
          const g = this.q('[data-overlay][data-lane="watcher"] [data-arrows]');
          const m = this.rel('watcher', this.q('[data-machine][data-lane="watcher"]'));
          const dr = this.rel('watcher', d);
          const a = this.drawArrowG(g, 'ah-watcher', m.r - 6, m.t + 30, dr.l + 6, dr.t + 16, { color:'#F76B54', w:2 });
          this.drawIn(a, 320); this.fadeRemove(a, 900, 300);
          if (!d) { resolve(); return; }
          this.tween(480, p => {
            const e = this.ease(p);
            d.style.opacity = String(e);
            d.style.transform = `translateY(${(14*(1-e)).toFixed(1)}px) scale(${(0.94 + 0.06*e).toFixed(3)})`;
          }, () => { d.style.opacity = '1'; d.style.transform = 'translateY(0) scale(1)'; resolve(); });
        });
      }
      pulseAt(lane, el) {
        const b = this.bodyEl(lane); const r = this.rel(lane, el);
        const ring = document.createElement('div'); ring.setAttribute('data-fx','');
        ring.style.cssText = `position:absolute; left:${(r.r-16).toFixed(0)}px; top:${(r.t+18).toFixed(0)}px; width:22px; height:22px; border-radius:50%; border:2px solid #F76B54; pointer-events:none; z-index:6;`;
        b.appendChild(ring);
        this.tween(820, p => { ring.style.transform = `scale(${(0.35 + 2.5*p).toFixed(2)})`; ring.style.opacity = String(0.7*(1-p)); }, () => ring.remove());
      }

      async runWatcher(id) {
        this.dimLane('manual', true); this.dimLane('watcher', false); this.scrollToLane('watcher');
        this.startLaneClock('watcher', id);
        await this.uploadDigital(id); if (this.runId !== id) return;
        await this.revealBrowser(id); if (this.runId !== id) return;
        this.setActions('watcher', 1);
        this.pulseAt('watcher', this.q('[data-digital][data-lane="watcher"]'));
        await this.sleep(240); if (this.runId !== id) return;

        this.FIELDS.forEach(f => {
          const rval = this.rcptVal('watcher', f.key), box = this.emr('watcher', f.key);
          const rp = this.rel('watcher', rval), bp = this.rel('watcher', box);
          const p = this.drawArrow('watcher', rp.r, rp.cy, bp.l, bp.cy, { color:'#F76B54', w:2.4 });
          const len = p.getTotalLength();
          p.style.strokeDasharray = len; p.style.strokeDashoffset = len; p.style.animation = 'flow .7s linear infinite';
          this.tween(380, t => { p.style.strokeDashoffset = String(len*(1-this.ease(t))); }, () => { p.style.strokeDasharray = '7 7'; p.style.strokeDashoffset = '0'; });
        });
        let filled = 0;
        this.FIELDS.forEach((f, i) => {
          setTimeout(() => {
            if (this.runId !== id) return;
            const box = this.emr('watcher', f.key);
            box.querySelector('[data-val]').textContent = f.value;
            this.highlight(this.rcptVal('watcher', f.key), 'ok');
            this.flash(box, 'ok'); filled++; this.setStatus('watcher', filled);
          }, 130 + i * 60);
        });
        await this.sleep(820); if (this.runId !== id) return;
        const sc2 = this.q('[data-screen][data-lane="watcher"]'); if (sc2) sc2.textContent = 'DONE';
        this.freezeLane('watcher');
      }

      buildLanePop(lane) {
        const pop = this.q(`[data-lanepop][data-lane="${lane}"]`); if (!pop) return;
        const isM = lane === 'manual';
        const accent = isM ? '#6B7B92' : '#F76B54';
        const label = isM ? 'Manual Entry' : 'Watcher';
        const timeVal = isM ? this.fmtMS(this.manualFinalSec) : '0.42s';
        const actLabel = isM ? 'Keystrokes' : 'Actions';
        const actVal = isM ? this.actions.manual : 1;
        const errVal = isM ? this.errors.manual : 0;
        const errColor = errVal > 0 ? '#e8705f' : '#5fc88f';
        const cell = (l, v, c) => `<div style="padding:0 16px;"><div style="font:500 9px 'IBM Plex Sans'; letter-spacing:.13em; text-transform:uppercase; color:#6f7a8a;">${l}</div><div style="font:600 30px/1 'IBM Plex Mono'; color:${c}; margin-top:7px;">${v}</div></div>`;
        pop.innerHTML = `
          <div style="background:#0c0f14; border-radius:13px; box-shadow:0 18px 48px rgba(0,0,0,.20); padding:20px 22px 22px; text-align:center;">
            <div style="display:inline-flex; align-items:center; gap:7px; font:600 12px 'IBM Plex Sans'; color:#fff; background:${accent}; padding:5px 12px; border-radius:6px;"><span style="width:7px;height:7px;border-radius:50%;background:#d7dde6;opacity:.9;"></span>${label}</div>
            <div style="display:flex; justify-content:center; margin-top:18px;">${cell('Time', timeVal, '#e7ecf3')}<div style="width:1px; background:#2a313d;"></div>${cell(actLabel, actVal, '#e7ecf3')}<div style="width:1px; background:#2a313d;"></div>${cell('Errors', errVal, errColor)}</div>
          </div>`;
      }
      async showLaneSpotlight(id, lane) {
        const scrim = this.q(`[data-lanescrim][data-lane="${lane}"]`);
        const pop = this.q(`[data-lanepop][data-lane="${lane}"]`);
        const card = this.q(`[data-lanecard][data-lane="${lane}"]`);
        const g = this.q(`[data-lanearrows][data-lane="${lane}"] [data-poparrows]`);
        if (!scrim || !pop) return;
        this.dimLane(lane, false);
        this.buildLanePop(lane);
        scrim.style.display = 'block'; pop.style.display = 'block';
        await this.showFade(id, [scrim], [pop]); if (this.runId !== id) return;
        const marker = `ah-pop-${lane}`;
        const popR = this.relTo(card, pop);
        ['[data-clock]','[data-actions]','[data-errors]'].forEach(sel => {
          const m = this.q(`${sel}[data-lane="${lane}"]`); if (!m) return;
          const mr = this.relTo(card, m);
          const p = this.drawArrowG(g, marker, mr.cx, mr.b + 3, popR.cx + (Math.random()*40-20), popR.t - 4, { color: lane==='manual'?'#6B7B92':'#F76B54', w:1.6, vertical:true });
          this.drawIn(p, 360);
        });
        scrim.style.pointerEvents = 'auto';
        await this.holdClick(id, scrim, 2900); if (this.runId !== id) return;
        if (g) g.innerHTML = '';
        await this.hideFade(id, [scrim], [pop]);
        scrim.style.display = 'none'; pop.style.display = 'none'; scrim.style.pointerEvents = 'none';
      }
      showFade(id, fadeEls, popEls) {
        return new Promise(resolve => {
          this.tween(300, p => {
            const e = this.ease(p);
            fadeEls.forEach(el => el && (el.style.opacity = String(e)));
            popEls.forEach(el => { if (el) { el.style.opacity = String(e); el.style.transform = `translate(-50%,-50%) scale(${(0.92+0.08*e).toFixed(3)})`; } });
          }, () => { fadeEls.forEach(el=>el&&(el.style.opacity='1')); popEls.forEach(el=>{ if(el){el.style.opacity='1'; el.style.transform='translate(-50%,-50%) scale(1)';} }); resolve(); });
        });
      }
      hideFade(id, fadeEls, popEls) {
        return new Promise(resolve => {
          this.tween(240, p => {
            const o = 1 - p;
            fadeEls.forEach(el => el && (el.style.opacity = String(o)));
            popEls.forEach(el => el && (el.style.opacity = String(o)));
          }, () => resolve());
        });
      }
      holdClick(id, el, ms) {
        return new Promise(resolve => {
          let done = false;
          const finish = () => { if (done) return; done = true; if (el) el.removeEventListener('click', finish); resolve(); };
          if (el) el.addEventListener('click', finish);
          setTimeout(finish, ms);
        });
      }

      countUp(el, target, fmt, dur) {
        if (!el) return;
        const id = this.runId, t0 = performance.now();
        const step = (now) => {
          if (this.runId !== id) return;
          let p = Math.min(1, (now - t0) / dur);
          p = 1 - Math.pow(1 - p, 3);
          el.textContent = fmt ? fmt(target * p) : Math.round(target * p);
          if (p < 1) requestAnimationFrame(step); else el.textContent = fmt ? fmt(target) : Math.round(target);
        };
        requestAnimationFrame(step);
      }
      compArrow(id, fromEl, toEl, color, marker, bow) {
        const ov = this.q('[data-pageoverlay]'); const g = this.q('[data-comp-arrows]');
        if (!ov || !fromEl || !toEl) return;
        const fr = this.relTo(ov, fromEl), tr = this.relTo(ov, toEl);
        const p = this.drawArrowG(g, marker, fr.cx, fr.b + 2, tr.cx, tr.t - 2, { color, w:1.7, vertical:true, bow: bow || 0 });
        p.style.opacity = '0.92';
        this.drawIn(p, 460);
        return p;
      }
      async showComparison(id) {
        // dim less than mid-race so the lanes/flow above stay legible behind the result
        this.dimLane('manual', true, '0.66'); this.dimLane('watcher', true, '0.66');
        const res = this.q('[data-results]');
        await this.sleep(60);
        this.tween(360, p => { res.style.opacity = String(this.ease(p)); }, () => res.style.opacity = '1');
        await this.sleep(360); if (this.runId !== id) return;

        const timeCell = this.q('[data-rescell="time"]');
        const keysCell = this.q('[data-rescell="keys"]');
        const errCell  = this.q('[data-rescell="err"]');
        const mc = this.q('[data-clock][data-lane="manual"]'),  wc = this.q('[data-clock][data-lane="watcher"]');
        const ma = this.q('[data-actions][data-lane="manual"]'), wa = this.q('[data-actions][data-lane="watcher"]');
        const me = this.q('[data-errors][data-lane="manual"]'),  we = this.q('[data-errors][data-lane="watcher"]');

        const a1 = this.compArrow(id, mc, timeCell, '#6B7B92', 'ah-comp-m', 70);
        const a2 = this.compArrow(id, wc, timeCell, '#F76B54', 'ah-comp-w', 30);
        await this.sleep(420); if (this.runId !== id) return;
        this.countUp(this.q('[data-rtime-m]'), this.manualFinalSec, (v)=>this.fmtMS(v), 650);
        this.countUp(this.q('[data-mult]'), Math.round(this.manualFinalSec/0.42), null, 750);
        this.fadeRemove(a1, 500, 320); this.fadeRemove(a2, 500, 320);
        await this.sleep(520); if (this.runId !== id) return;

        const b1 = this.compArrow(id, ma, keysCell, '#6B7B92', 'ah-comp-m', 70);
        const b2 = this.compArrow(id, wa, keysCell, '#F76B54', 'ah-comp-w', 30);
        await this.sleep(420); if (this.runId !== id) return;
        this.countUp(this.q('[data-ract-m]'), this.actions.manual, null, 650);
        this.fadeRemove(b1, 500, 320); this.fadeRemove(b2, 500, 320);
        await this.sleep(520); if (this.runId !== id) return;

        const c1 = this.compArrow(id, me, errCell, '#6B7B92', 'ah-comp-m', 70);
        const c2 = this.compArrow(id, we, errCell, '#F76B54', 'ah-comp-w', 30);
        await this.sleep(420); if (this.runId !== id) return;
        this.countUp(this.q('[data-rerr-m]'), this.errors.manual, null, 600);
        this.fadeRemove(c1, 500, 320); this.fadeRemove(c2, 500, 320);
        await this.sleep(500);

        this._progDone = true; setProg(1);
        const start = this.q('[data-start]');
        if (start) { start.disabled = false; start.style.opacity = '1'; start.style.cursor = 'pointer'; start.textContent = 'Run again'; }
      }
    }

    const race = new EMRRace(root);

    // Intro gate: show the context card first; the race begins only on the Begin click
    // (no auto-run). Reveal the card when the panel scrolls into view.
    if (intro) {
      const begin = intro.querySelector('[data-begin]');
      if (begin) begin.addEventListener('click', () => { intro.classList.add('gone'); race.start(); });
      new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) intro.classList.add('in'); }),
        { threshold: 0.4 }).observe(root);
    } else {
      // fallback: if the intro is ever absent, keep the old auto-run behaviour
      new IntersectionObserver((es, o) => es.forEach((e) => { if (e.isIntersecting) { race.start(); o.disconnect(); } }), { threshold: 0.25 }).observe(root);
    }
  })();
</script>
