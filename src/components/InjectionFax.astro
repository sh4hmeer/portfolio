<script is:inline>
  (function () {
    const root = document.getElementById('scene-root');
    if (!root) return;
    const intro = root.closest('[data-bench-scene]')?.querySelector('[data-intro]');

    class OneTap {
      eOut = (t) => 1 - Math.pow(1 - t, 3);
      eInOut = (t) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);
      clamp = (v, a = 0, b = 1) => Math.max(a, Math.min(b, v));
      lerp = (a, b, t) => a + (b - a) * t;
      pad = (n) => String(Math.floor(n)).padStart(2, "0");
      fmt = (sec) => this.pad(sec / 60) + ":" + this.pad(sec % 60) + "." + this.pad((sec * 100) % 100);
      mmss = (sec) => this.pad(sec / 60) + ":" + this.pad(sec % 60);
      seg = (t, a, b) => this.clamp((t - a) / (b - a));
      segE = (t, a, b) => this.eInOut(this.clamp((t - a) / (b - a)));

      tween = (dur, onP, onD) => {
        const t0 = Date.now();
        const id = setInterval(() => {
          let p = (Date.now() - t0) / dur;
          if (p >= 1) { p = 1; clearInterval(id); onP(1); onD && onD(); }
          else onP(this.eOut(p));
        }, 16);
        this._tweens.push(id);
        return id;
      };

      constructor(root) {
        this.root = root;
        this.props = { durationSec: 19, showGhostTrails: true };
        this._tweens = [];
        this.scale = 1;
        this.mount();
      }

      mount() {
        const $ = (id) => this.root.querySelector('#' + id);
        const ids = ["clock", "statusDot", "statusTxt", "intakeDoc", "faxRed", "faxGreen",
          "figR", "figR_armL", "figR_armR", "figR_legF", "figR_legB", "figR_head", "figR_pencil",
          "figG", "figG_armL", "figG_armR", "figG_legF", "figG_legB", "figG_head",
          "monitor", "monBtn", "monBtnTxt", "monFields", "monR0", "monR1", "monR2", "monR3",
          "gLight", "bigLight", "startFlash", "chipG", "chipR",
          "gazeLayer", "gazeLine0", "gazeLine1", "gazeLine2", "gazeLine3", "gazeRing", "gazeDot",
          "result", "manualVal", "toolVal", "factor"];
        this.els = {}; ids.forEach((i) => (this.els[i] = $(i)));
        this.ivals = [0, 1, 2, 3, 4, 5, 6, 7].map((i) => $("ival" + i));

        this.FLOOR = 540;
        this.ENTER = -130;
        this.RED_DESK = 268;
        this.GREEN_TAP = 620;
        this.GREEN_GRAB = 700;
        this.RED_PRINT = 812;
        this.RED_MEET = 935;
        this.GREEN_MEET = 1065;

        this.P = {
          gIn: [0, 1.4], gReach: [1.35, 1.9], gPress: [1.85, 2.2], gGen: [2.0, 2.7],
          gOut: [2.5, 3.1], gStep: [2.45, 3.1], gGrab: [3.0, 3.55], gExit: [4.7, 6.6], gLock: 3.15,
          rIn: [0, 2.7], rWrite: [3.0, 9.8], rToPrint: [9.8, 11.6], rPrint: [11.6, 13.4],
          rCollect: [13.3, 14.0], rBack: [14.1, 16.1], rCompare: [16.1, 18.4], rLock: 18.4,
          rExit: [18.4, 20.4], finish: 20.5,
        };

        this.running = false; this.timer = null;

        const NS = "http://www.w3.org/2000/svg";
        const tg = $("trails");
        this.trails = [];
        for (let i = 0; i < 20; i++) {
          const cl = document.createElementNS(NS, "g");
          cl.setAttribute("opacity", "0");
          cl.innerHTML =
            '<line x1="-7" y1="-46" x2="-7" y2="0" stroke="currentColor" stroke-width="15" stroke-linecap="round"></line>' +
            '<line x1="7" y1="-46" x2="7" y2="0" stroke="currentColor" stroke-width="15" stroke-linecap="round"></line>' +
            '<rect x="-17" y="-122" width="34" height="82" rx="17" fill="currentColor"></rect>' +
            '<circle cx="0" cy="-143" r="19" fill="currentColor"></circle>';
          tg.appendChild(cl);
          this.trails.push({ el: cl, birth: -1 });
        }
        this._trailIdx = 0; this._lastTrail = -1;

        this.reset();

        const s = this.root.querySelector('[data-start]'); if (s) s.addEventListener('click', () => this.start());
        const r = this.root.querySelector('[data-reset]'); if (r) r.addEventListener('click', () => this.reset());

        this.fit();
        addEventListener('resize', () => this.fit(), { passive: true });
        if (document.fonts && document.fonts.ready) document.fonts.ready.then(() => this.fit());
      }

      // scale the whole 1200px scene to fit the pinned viewport. all motion is in SVG
      // user-space, so a CSS transform on the root is safe (no rect-based arrow math).
      // measure with the result strip shown so it doesn't overflow when it appears.
      fit() {
        const root = this.root;
        root.style.transform = 'none';
        const res = this.els.result, fac = this.els.factor;
        const rd = res.style.display, ro = res.style.opacity, fd = fac.style.display, fo = fac.style.opacity;
        res.style.display = 'flex'; res.style.opacity = '0';
        fac.style.display = 'flex'; fac.style.opacity = '0';
        const w = root.offsetWidth, h = root.offsetHeight;
        res.style.display = rd; res.style.opacity = ro; fac.style.display = fd; fac.style.opacity = fo;
        const pinned = window.matchMedia('(min-width:761px)').matches;
        const RES = pinned ? 88 : 0;  // leave room for the bench slider tab strip
        const s = Math.min(1, (window.innerWidth - 24) / w, (window.innerHeight - 20 - RES) / h);
        this.scale = s;
        const ty = pinned ? RES + Math.max(0, (window.innerHeight - RES - h * s) / 2) : 0;
        root.style.transformOrigin = 'top center';
        root.style.transform = `translateY(${ty.toFixed(1)}px) scale(${s.toFixed(4)})`;
      }

      _clearTimers() {
        if (this.timer) { clearInterval(this.timer); this.timer = null; }
        (this._tweens || []).forEach(clearInterval);
        this._tweens = [];
      }

      aim(figX, pivotX, tx, ty) {
        const sx = figX + pivotX, sy = this.FLOOR - 112;
        return Math.atan2(ty - sy, tx - sx) * 180 / Math.PI - 90;
      }

      handWorld(rx, pivotX, armDeg) {
        const a = armDeg * Math.PI / 180;
        return { x: rx + pivotX + 58 * Math.sin(a), y: this.FLOOR - 112 + 58 * Math.cos(a) };
      }

      updateGaze(t) {
        const P = this.P, e = this.els;
        if (!(t >= P.rCompare[0] && t <= P.rCompare[1]) || !this._cmp) { e.gazeLayer.setAttribute("opacity", "0"); return; }
        e.gazeLayer.setAttribute("opacity", "1");
        const { itx, ity, ftx, fty, cs } = this._cmp;
        const IL = [[120, 51], [120, 91], [120, 151], [120, 171]];
        const FL = [[46, 131], [92, 184], [64, 226], [92, 258]];
        const iW = (k) => ({ x: itx + cs * IL[k][0], y: ity + cs * IL[k][1] });
        const fW = (k) => ({ x: ftx + cs * FL[k][0], y: fty + cs * FL[k][1] });
        const gp = this.clamp(this.seg(t, P.rCompare[0], P.rCompare[1]));
        const stepF = gp * 4, k = this.clamp(Math.floor(stepF), 0, 3), sub = this.clamp(stepF - k), mv = this.clamp(sub / 0.5);
        const a = iW(k), b = fW(k);
        const dx = this.lerp(a.x, b.x, this.eInOut(mv)), dy = this.lerp(a.y, b.y, this.eInOut(mv));
        e.gazeRing.setAttribute("cx", dx.toFixed(1)); e.gazeRing.setAttribute("cy", dy.toFixed(1));
        e.gazeDot.setAttribute("cx", dx.toFixed(1)); e.gazeDot.setAttribute("cy", dy.toFixed(1));
        const lines = [e.gazeLine0, e.gazeLine1, e.gazeLine2, e.gazeLine3];
        for (let j = 0; j < 4; j++) {
          const aa = iW(j); let ex = fW(j).x, ey = fW(j).y, op = 0;
          if (j < k) op = 0.42;
          else if (j === k) { op = 0.8; ex = dx; ey = dy; }
          lines[j].setAttribute("x1", aa.x.toFixed(1)); lines[j].setAttribute("y1", aa.y.toFixed(1));
          lines[j].setAttribute("x2", ex.toFixed(1)); lines[j].setAttribute("y2", ey.toFixed(1));
          lines[j].setAttribute("opacity", String(op));
        }
      }

      walk(t, env, freq) {
        const ph = t * freq;
        return {
          legF: Math.sin(ph) * 24 * env,
          legB: -Math.sin(ph) * 24 * env,
          arm: Math.sin(ph + Math.PI) * 16 * env,
          bob: Math.abs(Math.sin(ph)) * 5 * env,
        };
      }

      poseFig(p, x, bob, legF, legB, armR, armL, headDx) {
        const e = this.els;
        e["fig" + p].setAttribute("transform", "translate(" + x.toFixed(1) + "," + (this.FLOOR - bob).toFixed(1) + ")");
        e["fig" + p + "_legF"].setAttribute("transform", "rotate(" + legF.toFixed(1) + ",7,-46)");
        e["fig" + p + "_legB"].setAttribute("transform", "rotate(" + legB.toFixed(1) + ",-7,-46)");
        e["fig" + p + "_armR"].setAttribute("transform", "rotate(" + armR.toFixed(1) + ",12,-112)");
        e["fig" + p + "_armL"].setAttribute("transform", "rotate(" + armL.toFixed(1) + ",-12,-112)");
        e["fig" + p + "_head"].setAttribute("transform", "translate(" + (headDx || 0).toFixed(1) + ",0)");
      }

      start() {
        if (this.running) return;
        this._clearTimers();
        this.k = (this.props.durationSec || 19) / 19;
        this.useTrails = this.props.showGhostTrails !== false;
        this.clearVisuals();
        this._gDone = false; this._rDone = false; this._finished = false;
        this.running = true;
        this.els.statusDot.style.background = "#2E9E6B";
        this.els.statusTxt.textContent = "Running";
        this.els.startFlash.setAttribute("opacity", "0");
        this.tween(700, (p) => {
          this.els.startFlash.setAttribute("r", String(10 + p * 70));
          this.els.startFlash.setAttribute("opacity", String((1 - p) * 0.6));
        }, () => this.els.startFlash.setAttribute("opacity", "0"));

        this.t0 = Date.now();
        this.timer = setInterval(() => {
          const t = (Date.now() - this.t0) / 1000 / this.k;
          this.els.statusDot.style.opacity = String(0.45 + 0.55 * Math.abs(Math.sin(t * 4)));
          if (t >= this.P.finish) { this.tick(this.P.finish); this.finish(); return; }
          this.tick(t);
        }, 33);
      }

      clockAt(t) {
        const P = this.P;
        if (t <= P.gLock) return (t / P.gLock) * 7;
        if (t <= P.rLock) return 7 + (t - P.gLock) / (P.rLock - P.gLock) * 416;
        return 423;
      }

      finish() {
        if (this.timer) { clearInterval(this.timer); this.timer = null; }
        this.running = false; this._finished = true;
        this.els.statusDot.style.background = "#2E9E6B";
        this.els.statusDot.style.opacity = "1";
        this.els.statusTxt.textContent = "Complete";
        const r = this.els.result; r.style.display = "flex";
        this.tween(450, (p) => { r.style.opacity = String(p); });
        this.tween(1300,
          (p) => { this.els.manualVal.textContent = this.mmss(p * 423); this.els.toolVal.textContent = this.mmss(p * 7); },
          () => { this.els.manualVal.textContent = "07:03"; this.els.toolVal.textContent = "00:07"; this.fadeIn(this.els.factor, true); }
        );
      }

      fadeIn(el, flex) { el.style.display = flex ? "flex" : ""; this.tween(400, (p) => { el.style.opacity = String(p); }); }

      clearVisuals() {
        this.els.clock.textContent = "00:00.00";
        [this.els.chipG, this.els.chipR].forEach((e) => { e.style.opacity = "0"; e.setAttribute("opacity", "0"); });
        this.els.faxRed.setAttribute("opacity", "0");
        this.els.faxGreen.setAttribute("opacity", "0");
        this.els.intakeDoc.setAttribute("transform", "translate(316,254)");
        this.els.result.style.display = "none"; this.els.result.style.opacity = "0";
        this.els.factor.style.display = "none"; this.els.factor.style.opacity = "0";
        this.els.gLight.setAttribute("fill", "#3a3f48");
        this.els.bigLight.setAttribute("fill", "#3a3f48");
        this.els.gazeLayer.setAttribute("opacity", "0");
        this.setMonitor(false);
        this.ivals.forEach((v) => { v.style.clipPath = "inset(0 100% 0 0)"; });
        (this.trails || []).forEach((t) => { t.birth = -1; t.el.setAttribute("opacity", "0"); });
        this._trailIdx = 0; this._lastTrail = -1;
      }

      setMonitor(on) {
        const e = this.els;
        const rows = [e.monR0, e.monR1, e.monR2, e.monR3];
        rows.forEach((r) => r.setAttribute("fill", on ? "#2E9E6B" : "#232c38"));
        e.monFields.textContent = on ? "FIELDS 8/8" : "FIELDS 0/8";
        e.monFields.setAttribute("fill", on ? "#2E9E6B" : "#5a616b");
        e.monBtnTxt.textContent = on ? "✓ COMPOSED" : "GENERATE";
      }

      reset() {
        this._clearTimers();
        this.running = false; this._finished = false;
        this._gDone = false; this._rDone = false;
        this.k = (this.props.durationSec || 19) / 19;
        this.useTrails = this.props.showGhostTrails !== false;
        this.clearVisuals();
        this.els.statusDot.style.background = "#3a3f48";
        this.els.statusDot.style.opacity = "1";
        this.els.statusTxt.textContent = "Idle";
        this.tick(0);
      }

      tick(t) {
        const P = this.P, e = this.els;
        e.clock.textContent = this.fmt(this.clockAt(t));

        // ============ GREEN (automated) ============
        let gx, gbob = 0, glegF = 0, glegB = 0, gArmR = 0, gArmL = 0, gWalk = false, gEnv = 0;
        if (t <= P.gIn[1]) { gx = this.lerp(this.ENTER, this.GREEN_TAP, this.eOut(this.seg(t, P.gIn[0], P.gIn[1]))); gWalk = true; gEnv = Math.sin(this.seg(t, P.gIn[0], P.gIn[1]) * Math.PI); }
        else if (t <= P.gStep[1]) { gx = this.lerp(this.GREEN_TAP, this.GREEN_GRAB, this.segE(t, P.gStep[0], P.gStep[1])); }
        else if (t <= P.gExit[0]) { gx = this.GREEN_GRAB; }
        else { gx = this.lerp(this.GREEN_GRAB, this.GREEN_MEET, this.segE(t, P.gExit[0], P.gExit[1])); if (t > P.gExit[0] && t < P.gExit[1]) { gWalk = true; gEnv = Math.sin(this.seg(t, P.gExit[0], P.gExit[1]) * Math.PI); } }

        if (gWalk) { const w = this.walk(t, gEnv, 11.5); glegF = w.legF; glegB = w.legB; gArmR = w.arm; gArmL = -w.arm; gbob = w.bob; }
        if (t >= P.gReach[0] && t <= P.gGrab[0]) {
          const base = this.aim(gx, 12, gx + 55, this.FLOOR - 70);
          let dip = 0;
          if (t >= P.gPress[0] && t <= P.gPress[1]) dip = Math.sin(this.seg(t, P.gPress[0], P.gPress[1]) * Math.PI) * 10;
          gArmR = base + dip; gArmL = 6;
        }
        if (t >= P.gGrab[0] && t <= P.gExit[0]) { gArmR = this.aim(gx, 12, gx + 52, this.FLOOR - 178); gArmL = -14; }
        if (t > P.gExit[0]) { if (!gWalk) gArmR = 14; gArmL = -28; }
        this.poseFig("G", gx, gbob, glegF, glegB, gArmR, gArmL, 0);

        const genOn = t >= P.gGen[0];
        this.setMonitor(genOn);
        e.monitor.setAttribute("transform", "translate(620,352)" + (t >= P.gPress[0] && t <= P.gPress[1] ? " scale(0.995)" : ""));
        e.gLight.setAttribute("fill", t >= P.gGen[0] ? (t >= P.gOut[1] ? "#2E9E6B" : "#F7C25B") : "#3a3f48");
        let fgX, fgY, fgS = 0.14, fgOp = 0;
        if (t >= P.gOut[0]) {
          fgOp = 1;
          if (t <= P.gGrab[0]) { const p = this.eOut(this.seg(t, P.gOut[0], P.gOut[1])); fgS = 0.14; fgX = 770; fgY = this.lerp(452, 432, p); fgOp = p < 0.22 ? p / 0.22 : 1; }
          else if (t <= P.gGrab[1]) { const p = this.eInOut(this.seg(t, P.gGrab[0], P.gGrab[1])); fgS = this.lerp(0.14, 0.82, p); fgX = this.lerp(770, gx + 16, p); fgY = this.lerp(432, 258, p); }
          else if (t <= P.gExit[0]) { fgS = 0.82; fgX = gx + 16; fgY = 258; }
          else { const p = this.segE(t, P.gExit[0], P.gExit[1]); fgS = this.lerp(0.82, 0.42, p); fgX = gx + 10; fgY = this.lerp(258, this.FLOOR - 158, p); }
        }
        if (fgOp) { e.faxGreen.setAttribute("transform", "translate(" + fgX.toFixed(1) + "," + fgY.toFixed(1) + ") scale(" + fgS + ")"); }
        e.faxGreen.setAttribute("opacity", String(fgOp));

        // ============ RED (manual) ============
        let rx, rbob = 0, rlegF = 0, rlegB = 0, rArmR = 0, rArmL = 0, rWalk = false, rEnv = 0, rHeadDx = 0;
        if (t <= P.rIn[1]) { rx = this.lerp(this.ENTER, this.RED_DESK, this.eOut(this.seg(t, P.rIn[0], P.rIn[1]))); rWalk = true; rEnv = Math.sin(this.seg(t, P.rIn[0], P.rIn[1]) * Math.PI); }
        else if (t <= P.rToPrint[0]) { rx = this.RED_DESK; }
        else if (t <= P.rToPrint[1]) { rx = this.lerp(this.RED_DESK, this.RED_PRINT, this.segE(t, P.rToPrint[0], P.rToPrint[1])); rWalk = true; rEnv = Math.sin(this.seg(t, P.rToPrint[0], P.rToPrint[1]) * Math.PI); }
        else if (t <= P.rBack[0]) { rx = this.RED_PRINT; }
        else if (t <= P.rBack[1]) { rx = this.lerp(this.RED_PRINT, this.RED_DESK, this.segE(t, P.rBack[0], P.rBack[1])); rWalk = true; rEnv = Math.sin(this.seg(t, P.rBack[0], P.rBack[1]) * Math.PI); }
        else if (t <= P.rExit[0]) { rx = this.RED_DESK; }
        else { rx = this.lerp(this.RED_DESK, this.RED_MEET, this.segE(t, P.rExit[0], P.rExit[1])); rWalk = true; rEnv = Math.sin(this.seg(t, P.rExit[0], P.rExit[1]) * Math.PI); }

        if (rWalk) { const w = this.walk(t, rEnv, 8.4); rlegF = w.legF; rlegB = w.legB; rArmR = w.arm; rArmL = -w.arm; rbob = w.bob; }

        let writePen = null;
        if (t >= P.rWrite[0] && t <= P.rWrite[1]) {
          const wp = this.seg(t, P.rWrite[0], P.rWrite[1]);
          const ff = wp * 8, fi = Math.min(7, Math.floor(ff)), intra = this.clamp((ff - fi) / 0.8);
          for (let i = 0; i < 8; i++) {
            const rv = i < fi ? 1 : i === fi ? this.eInOut(intra) : 0;
            this.ivals[i].style.clipPath = "inset(0 " + ((1 - rv) * 100).toFixed(1) + "% 0 0)";
          }
          const penY = 254 + 48 + fi * 20; const penX = 316 + 84 + intra * 40;
          rArmR = this.aim(rx, 12, penX, penY) + Math.sin(t * 34) * 2;
          rArmL = 10;
        }
        if (t >= P.rCollect[0] && t <= P.rCompare[0]) { rArmR = this.aim(rx, 12, rx + 42, this.FLOOR - 222); rArmL = -10; }
        if (t >= P.rCompare[0] && t <= P.rCompare[1]) {
          rArmR = 64; rArmL = -64;
          rHeadDx = Math.sin((t - P.rCompare[0]) * 4.2) * 6;
        }
        if (t > P.rExit[0]) { rArmL = -30; if (!rWalk) rArmR = 12; }
        this.poseFig("R", rx, rbob, rlegF, rlegB, rArmR, rArmL, rHeadDx);
        const rWriting = t >= P.rWrite[0] && t <= P.rWrite[1];
        e.figR_pencil.setAttribute("opacity", rWriting ? "1" : "0");
        if (rWriting) e.figR_pencil.setAttribute("transform", "rotate(" + rArmR.toFixed(1) + ",12,-112)");

        const inCompare = t >= P.rCompare[0] && t <= P.rCompare[1];
        if (inCompare) {
          const cs = 0.62, fH = 290 * cs, iH = 214 * cs, iW = 210 * cs;
          const hR = this.handWorld(rx, 12, 64), hL = this.handWorld(rx, -12, -64);
          const ftx = hR.x - 4, fty = hR.y - fH + 6;
          const itx = hL.x - iW + 4, ity = hL.y - iH + 6;
          e.intakeDoc.setAttribute("transform", "translate(" + itx.toFixed(1) + "," + ity.toFixed(1) + ") scale(" + cs + ")");
          this._cmp = { itx, ity, ftx, fty, cs };
        } else {
          e.intakeDoc.setAttribute("transform", "translate(316,254)");
        }

        e.bigLight.setAttribute("fill", t >= P.rPrint[0] ? (t >= P.rPrint[1] ? "#2E9E6B" : "#F7C25B") : "#3a3f48");
        let frX, frY, frS = 0.14, frOp = 0;
        if (t >= P.rPrint[0]) {
          frOp = 1;
          if (t <= P.rCollect[0]) { const p = this.eOut(this.seg(t, P.rPrint[0], P.rPrint[1])); frS = 0.14; frX = 898; frY = this.lerp(446, 426, p); frOp = p < 0.22 ? p / 0.22 : 1; }
          else if (t <= P.rCollect[1]) { const p = this.eInOut(this.seg(t, P.rCollect[0], P.rCollect[1])); frS = this.lerp(0.14, 0.6, p); frX = this.lerp(898, rx + 30, p); frY = this.lerp(426, this.FLOOR - 300, p); }
          else if (t <= P.rCompare[0]) { frS = 0.6; frX = rx + 30; frY = this.FLOOR - 300; }
          else if (t <= P.rCompare[1]) { const c = this._cmp; frS = c.cs; frX = c.ftx; frY = c.fty; }
          else { const p = this.segE(t, P.rExit[0], P.rExit[1]); frS = this.lerp(0.62, 0.42, p); frX = rx + 10; frY = this.lerp(this.FLOOR - 312, this.FLOOR - 158, p); }
        }
        if (frOp) e.faxRed.setAttribute("transform", "translate(" + frX.toFixed(1) + "," + frY.toFixed(1) + ") scale(" + frS + ")");
        e.faxRed.setAttribute("opacity", String(frOp));

        if (this.useTrails && (gWalk || rWalk) && t - this._lastTrail > 0.16) {
          this._lastTrail = t;
          if (rWalk) this._spawnTrail(rx, "#F76B54", t);
          else if (gWalk) this._spawnTrail(gx, "#2E9E6B", t);
        }
        (this.trails || []).forEach((tr) => {
          if (tr.birth < 0) return;
          let o = 0.2 * (1 - (t - tr.birth) / 1.3);
          if (o <= 0) { o = 0; tr.birth = -1; }
          tr.el.setAttribute("opacity", String(o));
        });

        this.updateGaze(t);
        if (!this._gDone && t >= P.gLock) { this._gDone = true; this.fadeIn(this.els.chipG); }
        if (!this._rDone && t >= P.rLock) { this._rDone = true; this.fadeIn(this.els.chipR); }
      }

      _spawnTrail(x, color, t) {
        const tr = this.trails[this._trailIdx % this.trails.length]; this._trailIdx++;
        tr.el.style.color = color;
        tr.el.setAttribute("transform", "translate(" + x.toFixed(1) + "," + this.FLOOR + ")");
        tr.birth = t;
      }
    }

    const scene = new OneTap(root);

    // Intro gate: show the context card first; the benchmark begins only on the Begin
    // click (no auto-run). Reveal the card when the panel scrolls into view.
    if (intro) {
      const begin = intro.querySelector('[data-begin]');
      if (begin) begin.addEventListener('click', () => { intro.classList.add('gone'); scene.start(); });
      new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) intro.classList.add('in'); }),
        { threshold: 0.4 }).observe(root);
    } else {
      new IntersectionObserver((es, o) => es.forEach((e) => { if (e.isIntersecting) { scene.start(); o.disconnect(); } }), { threshold: 0.3 }).observe(root);
    }
  })();
</script>
