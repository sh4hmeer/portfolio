      <div style="font-size:9px;letter-spacing:.13em;text-transform:uppercase;color:#6f7681;">Automation Benchmark · Injection Orders</div>
      <div style="font-size:16px;font-weight:600;letter-spacing:-.01em;color:#EEF0F3;white-space:nowrap;">Injection order <span style="color:#6f7681;font-weight:400;">→</span> fax-ready document</div>
      <div style="display:flex;gap:18px;margin-top:3px;">
        <div style="display:flex;align-items:center;gap:7px;"><span style="width:9px;height:9px;border-radius:2px;background:#2E9E6B;"></span><span style="font-size:9px;letter-spacing:.13em;text-transform:uppercase;color:#8a929c;">Automated · fast</span></div>
        <div style="display:flex;align-items:center;gap:7px;"><span style="width:9px;height:9px;border-radius:2px;background:#F76B54;"></span><span style="font-size:9px;letter-spacing:.13em;text-transform:uppercase;color:#8a929c;">Manual · slow</span></div>
      </div>
    </div>
    <div style="display:flex;flex-direction:column;align-items:center;gap:5px;">
      <div style="font-size:9px;letter-spacing:.13em;text-transform:uppercase;color:#6f7681;">Shared stopwatch</div>
      <div id="clock" style="font-family:'IBM Plex Mono',monospace;font-size:46px;font-weight:500;letter-spacing:-.01em;line-height:1;color:#EEF0F3;font-variant-numeric:tabular-nums;">00:00.00</div>
    </div>
    <div style="display:flex;flex-direction:column;align-items:flex-end;gap:7px;">
      <div style="display:flex;align-items:center;gap:8px;">
        <span id="statusDot" style="width:9px;height:9px;border-radius:50%;background:#3a3f48;"></span>
        <span id="statusTxt" style="font-size:9px;letter-spacing:.13em;text-transform:uppercase;color:#8a929c;">Idle</span>
      </div>
      <div style="font-size:9px;letter-spacing:.13em;text-transform:uppercase;color:#8a929c;">Same source · same output</div>
    </div>
  </div>

